---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import rawBody from '../../mirror/home.body.html?raw';
import homeHead from '../../mirror/home.head.html?raw';
import bodyClass from '../../mirror/home.bodyclass.txt?raw';
import archiveShell from '../../mirror/archive.shell.html?raw';
import archiveHead from '../../mirror/event.head.html?raw';
import { getArticlesByPublishDate, getArticlesInCategory, type CardItem } from '../../lib/posts';

const news = (await getArticlesByPublishDate()).slice(0, 4);
const lectures = await getArticlesInCategory('event');

const now = new Date();
const todayUTC = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
const upcoming = lectures.filter((lecture) => lecture.sortKey >= todayUTC).sort((a, b) => a.sortKey - b.sortKey);
const next: CardItem | undefined = upcoming[0] ?? lectures[0];

const esc = (value: string) =>
  value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
const ymd = (date: Date) =>
  `${date.getUTCFullYear()}-${String(date.getUTCMonth() + 1).padStart(2, '0')}-${String(date.getUTCDate()).padStart(2, '0')}`;
const slugOf = (url: string) => esc(url.split('/').filter(Boolean).pop() ?? '');
const categoryClasses = (categories: string[]) => categories.map((category) => `category-${esc(category)}`).join(' ');

const NEWS_STYLE =
  '<style id="elementor-post-978">.elementor-978 .elementor-element.elementor-element-3a6f56e4 .elementor-icon-list-icon{width:14px;}.elementor-978 .elementor-element.elementor-element-3a6f56e4 .elementor-icon-list-icon i{font-size:14px;}.elementor-978 .elementor-element.elementor-element-3a6f56e4 .elementor-icon-list-icon svg{--e-icon-list-icon-size:14px;}.elementor-978 .elementor-element.elementor-element-3a6f56e4 > .elementor-widget-container{margin:0px 16px 0px 0px;}.elementor-978 .elementor-element.elementor-element-3a6f56e4{width:initial;max-width:initial;}.elementor-978 .elementor-element.elementor-element-115bb31a > .elementor-widget-container{margin:7px 0px 0px 0px;}.elementor-978 .elementor-element.elementor-element-115bb31a{width:initial;max-width:initial;}</style>';

const newsItem = (item: CardItem) => {
  const slug = slugOf(item.url);
  const classes = categoryClasses(item.categories);
  return `<article id="post-${slug}" class="elementor-post elementor-grid-item ecs-post-loop post-${slug} post type-post status-publish format-standard has-post-thumbnail hentry ${classes}">
<div data-elementor-type="loop" data-elementor-id="978" class="elementor elementor-978 elementor-location-single post-${slug} post type-post status-publish format-standard has-post-thumbnail hentry ${classes}" data-elementor-settings="[]">
<div class="elementor-section-wrap">
<section class="elementor-section elementor-top-section elementor-element elementor-element-39d4d691 elementor-section-boxed elementor-section-height-default elementor-section-height-default" data-id="39d4d691" data-element_type="section">
<div class="elementor-container elementor-column-gap-default">
<div class="elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-51ff6216" data-id="51ff6216" data-element_type="column">
<div class="elementor-widget-wrap elementor-element-populated">
<div class="elementor-element elementor-element-3a6f56e4 elementor-widget__width-initial elementor-widget elementor-widget-post-info" data-id="3a6f56e4" data-element_type="widget" data-widget_type="post-info.default">
<div class="elementor-widget-container">
<ul class="elementor-icon-list-items elementor-post-info">
<li class="elementor-icon-list-item elementor-repeater-item-f15c625" itemprop="datePublished">
<span class="elementor-icon-list-text elementor-post-info__item elementor-post-info__item--type-date">${ymd(item.date)}</span>
</li>
</ul>
</div>
</div>
<div class="elementor-element elementor-element-115bb31a elementor-widget__width-initial elementor-widget elementor-widget-theme-post-title elementor-page-title elementor-widget-heading" data-id="115bb31a" data-element_type="widget" data-widget_type="theme-post-title.default">
<div class="elementor-widget-container">
<p class="elementor-heading-title elementor-size-default"><a href="${esc(item.url)}">${esc(item.title)}</a></p>
</div>
</div>
</div>
</div>
</div>
</section>
</div>
</div>
</article>`;
};

const nextBanner = (item?: CardItem) =>
  item?.thumb
    ? `<a href="${esc(item.url)}"><img width="920" height="450" src="${esc(item.thumb)}" class="attachment-full size-full" alt="${esc(item.title)}" loading="lazy" /></a>`
    : '';

function spliceArticles(html: string, start: string, endAnchor: string, replacement: string, label: string): string {
  const startAt = html.indexOf(start);
  if (startAt < 0) throw new Error(`lecture merge[${label}]: start anchor not found`);
  const anchorAt = html.indexOf(endAnchor, startAt);
  if (anchorAt < 0) throw new Error(`lecture merge[${label}]: end anchor not found`);
  const endAt = html.indexOf('</article>', anchorAt);
  if (endAt < 0) throw new Error(`lecture merge[${label}]: closing </article> not found`);
  return html.slice(0, startAt) + replacement + html.slice(endAt + '</article>'.length);
}

function removeSection(html: string, dataId: string): string {
  const idAt = html.indexOf(`data-id="${dataId}"`);
  if (idAt < 0) throw new Error(`lecture merge[${dataId}]: section not found`);
  const startAt = html.lastIndexOf('<section', idAt);
  if (startAt < 0) throw new Error(`lecture merge[${dataId}]: opening <section> not found`);

  const sectionTag = /<\/?section\b[^>]*>/g;
  sectionTag.lastIndex = startAt;
  let depth = 0;
  let match: RegExpExecArray | null;
  while ((match = sectionTag.exec(html))) {
    depth += match[0].startsWith('</') ? -1 : 1;
    if (depth === 0) return html.slice(0, startAt) + html.slice(sectionTag.lastIndex);
  }
  throw new Error(`lecture merge[${dataId}]: closing </section> not found`);
}

let body = rawBody;
body = spliceArticles(
  body,
  '<article id="post-4981"',
  '/2026/02/vol-70/',
  NEWS_STYLE + news.map(newsItem).join('\n'),
  'news'
);

{
  const start = '<a href="/2026/03/vol-72" target="_blank">';
  const startAt = body.indexOf(start);
  if (startAt < 0) throw new Error('lecture merge[next]: start anchor not found');
  const endAt = body.indexOf('</a>', startAt);
  if (endAt < 0) throw new Error('lecture merge[next]: closing </a> not found');
  body = body.slice(0, startAt) + nextBanner(next) + body.slice(endAt + '</a>'.length);
}

// The merged page keeps only the existing hero, NEXT LECTURE, and NEWS blocks.
body = removeSection(body, '78e88d11'); // LECTURE SERIES
body = removeSection(body, '494a4542'); // 「現実を科学する」とは？
body = removeSection(body, '1b1b0b70'); // CONTACT

const [archiveBeforeRaw, archiveRest] = archiveShell.split('<!--RS_TITLE-->');
const archiveBefore = archiveBeforeRaw.replace(
  'data-id="6ebdf687"',
  'id="lectures" data-id="6ebdf687"'
);
const [archiveBetween, archiveAfter] = archiveRest.split('<!--RS_CARDS-->');
const mergedHead = `${homeHead}
${archiveHead}
<style>
  .elementor-976 .elementor-element.elementor-element-6ebdf687 {
    margin-top: 96px;
    padding-bottom: 120px;
  }
  @media (max-width: 1024px) {
    .elementor-976 .elementor-element.elementor-element-6ebdf687 {
      margin-top: 72px;
      padding-bottom: 80px;
    }
  }
</style>`;
---
<BaseLayout
  title="LECTURE - 現実科学ラボ"
  bodyClass={bodyClass.trim()}
  headerVariant="home"
  headExtra={mergedHead}
>
  <Fragment set:html={body} />
  <Fragment set:html={archiveBefore} />
  LECTURES
  <Fragment set:html={archiveBetween} />
  {lectures.map((lecture) => (
    <PostCard url={lecture.url} title={lecture.title} thumb={lecture.thumb} />
  ))}
  <Fragment set:html={archiveAfter} />
</BaseLayout>
