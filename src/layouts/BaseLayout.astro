---
// Faithful chrome from the original Elementor site. Header/footer/scripts and the
// vendored CSS are mirrored verbatim; pages provide their own per-page inline
// styles (headExtra) and body content via the default slot.
import headLinks from '../mirror/head-links.html?raw';
import headerHome from '../mirror/header-home.html?raw';
import headerInner from '../mirror/header-inner.html?raw';
import footerHtml from '../mirror/footer.html?raw';
import scriptsHtml from '../mirror/scripts.html?raw';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  headerVariant?: 'home' | 'inner';
  headExtra?: string;
  ogImage?: string;
}
const {
  title,
  description = '科学技術を実装し、より豊かな『現実』を発見するためのギルド',
  bodyClass = '',
  headerVariant = 'inner',
  headExtra = '',
  ogImage,
} = Astro.props;

const header = headerVariant === 'home' ? headerHome : headerInner;

// Canonical / OG must reflect the actual deployment, not the old production WP site.
// build:pages sets these to the staging origin+base; default build uses the
// production domain at root (for the eventual custom-domain cutover).
const SITE_ORIGIN = process.env.SITE_ORIGIN || 'https://reality-science.com';
const BASE_PATH = process.env.BASE_PATH || '';
const canonical = `${SITE_ORIGIN}${BASE_PATH}${Astro.url.pathname}`;
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${SITE_ORIGIN}${BASE_PATH}${ogImage}`)
  : undefined;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ja_JP" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <Fragment set:html={headLinks} />
    {headExtra && <Fragment set:html={headExtra} />}
  </head>
  <body class={bodyClass}>
    <Fragment set:html={header} />
    <slot />
    <Fragment set:html={footerHtml} />
    <Fragment set:html={scriptsHtml} />
    <script is:inline>
      // Stretch Section — Elementor expands `.elementor-section-stretched` to the
      // full viewport width via JS at runtime. Without it, stretched sections (the
      // hero, etc.) stay at the boxed container width and show white side-margins on
      // wide screens. Replicate Elementor's behavior: width = viewport, margin-left =
      // -offset so the section aligns to the viewport's left edge.
      (function () {
        function stretch() {
          var vw = document.documentElement.clientWidth;
          var list = document.querySelectorAll('.elementor-section-stretched');
          for (var i = 0; i < list.length; i++) {
            var s = list[i];
            s.style.width = '';
            s.style.marginLeft = '';
            s.style.marginRight = '';
            var offset = s.getBoundingClientRect().left + (window.pageXOffset || 0);
            s.style.width = vw + 'px';
            s.style.marginLeft = -offset + 'px';
          }
        }
        stretch();
        window.addEventListener('resize', stretch);
        window.addEventListener('load', stretch);
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', stretch);
      })();
    </script>
    <script is:inline>
      // Mobile hamburger toggle — Elementor's own JS isn't reliably bootstrapped on
      // the static mirror, so drive the menu directly (matches Elementor's behavior).
      document.addEventListener('click', function (e) {
        var t = e.target.closest && e.target.closest('.elementor-menu-toggle');
        if (!t) return;
        var on = t.classList.toggle('elementor-active');
        t.setAttribute('aria-expanded', on ? 'true' : 'false');
        var icon = t.querySelector('i');
        if (icon) icon.className = on ? 'eicon-close' : 'eicon-menu-bar';
        var dd = t.parentElement && t.parentElement.querySelector('.elementor-nav-menu--dropdown');
        if (dd) {
          dd.setAttribute('aria-hidden', on ? 'false' : 'true');
          dd.style.display = on ? 'block' : 'none';
        }
      });

      // Video-playlist widgets build their player via Elementor Pro JS (not
      // bootstrapped on the static mirror), leaving the player area empty. Inject
      // the first PV video as a responsive iframe so the box isn't blank.
      document.querySelectorAll('.elementor-widget-video-playlist').forEach(function (w) {
        var cw = w.querySelector('.e-tabs-content-wrapper');
        if (!cw || cw.querySelector('iframe')) return;
        var s;
        try { s = JSON.parse((w.getAttribute('data-settings') || '').replace(/&quot;/g, '"')); } catch (e) { return; }
        var url = (s && s.tabs && s.tabs[0] && s.tabs[0].youtube_url) || '';
        var m = url.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
        if (!m) return;
        cw.innerHTML =
          '<div style="position:relative;width:100%;padding-bottom:56.25%;height:0;overflow:hidden;">' +
          '<iframe src="https://www.youtube.com/embed/' + m[1] + '?rel=0" ' +
          'style="position:absolute;inset:0;width:100%;height:100%;border:0;" allowfullscreen loading="lazy"></iframe></div>';
      });
    </script>
  </body>
</html>
